# Supabase Dashboard -> Project Settings -> Data API -> Project URL
SUPABASE_URL=

# Supabase Dashboard -> Project Settings -> Data API -> Project API keys -> service_role
# Backend only, never expose this client-side. Used both for data access and to validate
# the session tokens the frontend sends (works for Google sign-in and magic link alike).
SUPABASE_KEY=

# Google AI Studio
GEMINI_API_KEY=

# Comma-separated list of frontend origins allowed to call this API.
# Local dev default is http://localhost:3000 if unset. Add your deployed frontend URL too, e.g.:
# CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app
CORS_ORIGINS=
