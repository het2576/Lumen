# FastAPI backend URL (local: http://localhost:8000, deployed: your Render URL)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase Dashboard -> Project Settings -> Data API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase Dashboard -> Project Settings -> Data API -> Project API keys -> anon/public
# Safe to expose client-side by design (RLS is what constrains it) — never put service_role here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google sign-in needs NO env var here — its Client ID/Secret are configured entirely in
# Supabase Dashboard -> Authentication -> Providers -> Google, not in this app. See the
# "Auth (Google sign-in)" section in the root README for the Google Cloud Console setup steps.
